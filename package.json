    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "next": "16.3.0-canary.89",
    "next-themes": "^0.4.6",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
